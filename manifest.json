{
  "manifest_version": 3,
  "name": "Email Scraper",
  "version": "1.0",
  "permissions": ["activeTab", "scripting", "downloads"],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scrape Email"
  }
}